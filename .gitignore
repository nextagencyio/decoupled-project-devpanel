# Composer
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/libraries/

# Drupal
# NOTE: settings.php is COMMITTED (not ignored) because DevPanel needs it
# to exist before init.sh runs. It contains the DevPanel settings include.
/web/sites/*/settings.local.php
/web/sites/*/services.yml
/web/sites/*/files/

# Private files
/private/

# Environment
.env
.env.local

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Logs
/logs/*.log

