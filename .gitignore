# Composer
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/libraries/

# Drupal
# NOTE: settings.php is COMMITTED (not ignored) because DevPanel needs it
# to exist before init.sh runs. It contains the DevPanel settings include.
/web/sites/*/settings.local.php
/web/sites/*/services.yml
# Ignore files/ contents but keep the directory structure + .gitkeep files
# so DevPanel has writable dirs before init.sh runs.
/web/sites/*/files/*
!/web/sites/*/files/.gitkeep
!/web/sites/*/files/media-icons/
!/web/sites/*/files/media-icons/generic/
!/web/sites/*/files/media-icons/generic/.gitkeep

# Private files — ignore contents but keep dir + .gitkeep
/private/*
!/private/.gitkeep

# Environment
.env
.env.local

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Logs
/logs/*.log

# DevPanel
.devpanel/salt.txt
.devpanel/dumps/

# DDEV
.ddev/.ddev-docker-compose-*
.ddev/db_snapshots/
.ddev/.homeadditions
.ddev/.sshimageBuild
.ddev/sequelpro.spf
.ddev/.webimageBuild
.ddev/xhprof/
/.editorconfig
/.gitattributes