<?php

/**
 * @file
 * Adds a "Design Studio" tab to node pages that launches the Puck visual editor
 * with signed auth tokens. Only active when enabled and configured for specific
 * content types.
 */

use Drupal\Component\Utility\Crypt;
use Drupal\Core\Url;

/**
 * Check if dc_puck is enabled and configured for a given content type.
 */
function dc_puck_is_enabled_for_bundle(string $bundle): bool {
  $enabled = \Drupal::state()->get('dc_puck.enabled', FALSE);
  if (!$enabled) {
    return FALSE;
  }

  $enabledTypes = \Drupal::state()->get('dc_puck.enabled_content_types', []);
  return in_array($bundle, $enabledTypes);
}

/**
 * Generate a signed token for a user to edit a specific node.
 */
function dc_puck_generate_token(int $uid, int $nid): string {
  $secret = dc_puck_get_secret();
  $timestamp = time();
  $payload = "{$uid}:{$nid}:{$timestamp}";
  $hmac = hash_hmac('sha256', $payload, $secret);
  return base64_encode("{$payload}:{$hmac}");
}

/**
 * Get or create the HMAC secret for token signing.
 */
function dc_puck_get_secret(): string {
  $secret = \Drupal::state()->get('dc_puck.token_secret', '');
  if (empty($secret)) {
    $secret = Crypt::randomBytesBase64(32);
    \Drupal::state()->set('dc_puck.token_secret', $secret);
  }
  return $secret;
}

/**
 * Build a static Puck editor placeholder URL (no token).
 * The token is fetched client-side via JS so the page stays cacheable.
 */
function dc_puck_editor_url(int $nid): ?string {
  $puck_url = \Drupal::state()->get('dc_puck.editor_url', '');
  if (empty($puck_url)) {
    return NULL;
  }

  if (!\Drupal::currentUser()->id()) {
    return NULL;
  }

  // Return a placeholder — JS will replace with a tokenized URL on click.
  return 'internal:/api/puck/token/' . $nid;
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * Adds a styled "Design Studio" tab to node pages for enabled content types.
 */
function dc_puck_menu_local_tasks_alter(&$data, $route_name, &$cacheability) {
  if (!in_array($route_name, ['entity.node.canonical', 'entity.node.edit_form'])) {
    return;
  }

  $node = \Drupal::routeMatch()->getParameter('node');
  if (!$node) {
    return;
  }

  // Check if dc_puck is enabled for this content type.
  if (!dc_puck_is_enabled_for_bundle($node->bundle())) {
    return;
  }

  // Check if node has the configured sections field.
  $sectionsField = \Drupal::state()->get('dc_puck.sections_field', 'field_sections');
  if (!$node->hasField($sectionsField)) {
    return;
  }

  $puck_url = \Drupal::state()->get('dc_puck.editor_url', '');
  if (empty($puck_url) || !\Drupal::currentUser()->id()) {
    return;
  }

  $nid = $node->id();

  // Add the Design Studio tab. The href is a placeholder (#) — JS fetches
  // a fresh token on click so the page stays fully cacheable.
  $data['tabs'][0]['dc_puck.design_studio'] = [
    '#theme' => 'menu_local_task',
    '#link' => [
      'title' => [
        '#markup' => '<span style="display:inline-flex;align-items:center;gap:6px;">'
          . '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.855z"/></svg>'
          . 'Design Studio</span>',
      ],
      'url' => Url::fromRoute('<none>'),
      'localized_options' => [
        'attributes' => [
          'class' => ['dc-puck-design-tab'],
          'data-puck-nid' => $nid,
        ],
      ],
    ],
    '#active' => FALSE,
    '#weight' => 100,
    '#access' => $node->access('update'),
  ];

  $cacheability->addCacheContexts(['user', 'route']);
}

/**
 * Implements hook_page_attachments().
 */
function dc_puck_page_attachments(array &$attachments) {
  // Only attach CSS if dc_puck is enabled.
  if (!\Drupal::state()->get('dc_puck.enabled', FALSE)) {
    return;
  }

  $attachments['#attached']['html_head'][] = [
    [
      '#type' => 'html_tag',
      '#tag' => 'style',
      '#value' => '
        .dc-puck-design-tab {
          background: linear-gradient(135deg, #7c3aed, #2563eb) !important;
          color: #fff !important;
          border-radius: 6px !important;
          padding: 6px 14px !important;
          font-weight: 600 !important;
          font-size: 13px !important;
          text-decoration: none !important;
          transition: opacity 0.2s !important;
          border: none !important;
        }
        .dc-puck-design-tab:hover {
          opacity: 0.9 !important;
          color: #fff !important;
        }
        .dc-puck-design-tab svg {
          vertical-align: middle;
        }
      ',
    ],
    'dc_puck_styles',
  ];

  // JS to fetch a fresh token on Design Studio tab click.
  $attachments['#attached']['html_head'][] = [
    [
      '#type' => 'html_tag',
      '#tag' => 'script',
      '#value' => '
        document.addEventListener("click", function(e) {
          var link = e.target.closest("[data-puck-nid]");
          if (!link) return;
          e.preventDefault();
          var nid = link.getAttribute("data-puck-nid");
          link.style.opacity = "0.6";
          link.style.pointerEvents = "none";
          fetch("/api/puck/token/" + nid, { credentials: "same-origin" })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.url) window.location.href = data.url;
              else alert("Could not generate editor token.");
            })
            .catch(function() { alert("Could not reach token endpoint."); })
            .finally(function() {
              link.style.opacity = "";
              link.style.pointerEvents = "";
            });
        });
      ',
    ],
    'dc_puck_token_js',
  ];
}
